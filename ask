#!/usr/bin/env bash

set -euo pipefail

: "${ASK_API_URL:?ASK_API_URL is not set}"
: "${ASK_MODEL:?ASK_MODEL is not set}"
: "${ASK_API_KEY:?ASK_API_KEY is not set}"

stdin_text=""
if [ ! -t 0 ]; then
    stdin_text="$(cat)"
fi

args_text="$*"

if [ -n "$args_text" ] && [ -n "$stdin_text" ]; then
    user_prompt="${args_text}"$'\n'"${stdin_text}"
elif [ -n "$args_text" ]; then
    user_prompt="$args_text"
elif [ -n "$stdin_text" ]; then
    user_prompt="$stdin_text"
else
    echo "Usage: ask \"your prompt\""
    echo "       or: echo \"text\" | ask \"instruction\""
    exit 1
fi

payload=$(jq -n \
  --arg model "$ASK_MODEL" \
  --arg system "You are a CLI tool. Output plain text only. No yapping. Keep the output concise." \
  --arg user "$user_prompt" \
  '{
    model: $model,
    messages: [
      {role: "system", content: $system},
      {role: "user", content: $user}
    ],
    temperature: 0.2
  }')

response=$(curl -s -w "\n%{http_code}" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $ASK_API_KEY" \
  -d "$payload" \
  "$ASK_API_URL")

http_code=$(echo "$response" | tail -n 1)
body=$(echo "$response" | sed '$d')

if [ "$http_code" -ne 200 ]; then
    api_error=$(echo "$body" | jq -r '.error.message // "Unknown error"')
    echo "API Error (HTTP $http_code): $api_error" >&2
    exit 1
fi

echo "$body" | jq -r '.choices[0].message.content // empty'
